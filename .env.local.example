# Copy this file to .env.local and fill in real values

# --- Supabase (get from Supabase project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Service role key — DO NOT expose to client. Used only in server actions.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# --- App ---
NEXT_PUBLIC_SITE_URL=https://www.shycares.in

# --- Zoho Books (delivery acknowledgement) ---
# Org ID (India): 60074794920
ZOHO_ORG_ID=60074794920
# OAuth client — create at https://api-console.zoho.in → Self Client → Server-based
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# Generate with scope: ZohoBooks.salesorders.ALL,ZohoBooks.contacts.READ
ZOHO_REFRESH_TOKEN=
